# NetRecall — Environment Configuration
# Copy this file to .env and fill in your keys.

# ── Groq ─────────────────────────────────────────────────────────────────────
# https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Hindsight Cloud ───────────────────────────────────────────────────────────
# https://ui.hindsight.vectorize.io → Connect to Hindsight
HINDSIGHT_BASE_URL=https://api.hindsight.vectorize.io
HINDSIGHT_API_KEY=hsk_your_hindsight_api_key_here

# ── Twilio (real phone call integration) ─────────────────────────────────────
# https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Public URL of the webhook server.
# In development: run  ngrok http 5050  and paste the https URL here.
# In production:  use your real domain, e.g. https://netrecall.example.com
# NO trailing slash.
WEBHOOK_BASE_URL=https://your-ngrok-subdomain.ngrok.io
